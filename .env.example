# ─────────────────────────────────────────────────────────────────────────────
# Black Door — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=BlackDoor
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Tashkent

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=blackdoor
DB_USERNAME=blackdoor
DB_PASSWORD=secret

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ─── Cache / Queue / Session ─────────────────────────────────────────────────
CACHE_DRIVER=redis
CACHE_PREFIX=blackdoor_cache_
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Broadcasting (Laravel Reverb) ──────────────────────────────────────────
BROADCAST_DRIVER=reverb
REVERB_APP_ID=blackdoor
REVERB_APP_KEY=blackdoor-key
REVERB_APP_SECRET=blackdoor-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── Report Service ─────────────────────────────────────────────────────────
REPORT_SERVICE_URL=http://reports:8001

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@blackdoor.local"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug
